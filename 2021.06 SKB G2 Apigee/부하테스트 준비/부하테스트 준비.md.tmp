```
더미 H/E 구성  
wget [https://openresty.org/package/centos/openresty.repo](https://openresty.org/package/centos/openresty.repo)  
yum install -y openresty
```
 
```
systemctl start openresty  
systemctl enable openresty
```
 
```
mkdir /usr/local/openresty/nginx/conf.d  
vi /usr/local/openresty/nginx/conf.d/dummy.confc
```
   

```
        location /dummy0 {  
            echo_exec /dummy/index.html;  
        }
```
 
